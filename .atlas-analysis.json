  "keyFeatures": [
    "Async PHP API for Telegram MTProto protocol",
    "Event-driven update handling with filters",
    "File upload/download up to 4GB with full parallelization",
    "Secret chats and VoIP calls support",
    "Plugin system for extensibility",
    "Multiple database backends (MySQL, PostgreSQL, Redis)",
    "Built-in ORM and IPC support",
    "Prometheus metrics integration",
    "Docker support with official images"
  ],
